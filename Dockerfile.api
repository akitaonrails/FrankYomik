# Stage 1: Build static Go binary
FROM golang:1.25-bookworm AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/ cmd/
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /frank-api ./cmd/server/

# Stage 2: Minimal runtime
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /frank-api /frank-api

EXPOSE 8080
ENTRYPOINT ["/frank-api"]
