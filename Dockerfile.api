# Stage 1: Build static Go binary
FROM golang:1.25-bookworm AS builder

ARG APP_UID=1026
ARG APP_GID=1026

WORKDIR /build
COPY server/go.mod server/go.sum ./
RUN go mod download

COPY server/*.go ./
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /frank-api .

# Stage 2: Minimal runtime
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /frank-api /frank-api

EXPOSE 8080
ENTRYPOINT ["/frank-api"]
